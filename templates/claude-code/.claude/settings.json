{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -u +%FT%TZ)] Write: $(echo $CLAUDE_TOOL_INPUT | jq -r '.file_path')\" >> \"$CLAUDE_PROJECT_DIR\"/.claude/write.log",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
