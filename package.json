{
  "name": "ai-setup-cli",
  "version": "1.6.0",
  "description": "One command to configure any AI coding tool in your project",
  "type": "commonjs",
  "bin": {
    "ai-setup-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "claude",
    "copilot",
    "cursor",
    "gemini",
    "opencode",
    "setup",
    "cli"
  ],
  "license": "MIT",
  "author": "Aridane Martin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aridanemartin/ai-setup-cli.git"
  },
  "homepage": "https://github.com/aridanemartin/ai-setup-cli#readme",
  "bugs": {
    "url": "https://github.com/aridanemartin/ai-setup-cli/issues"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
